# griever environment variables.
#
# Copy to .env for local development; in production these come from Google
# Cloud Run --set-env-vars (or, preferably, Secret Manager — see Tier 2 of
# the deployment plan).


# --- Required ---

# RapidAPI key for "Real-Time Real Estate Data" (real-time-real-estate-data.p.rapidapi.com).
# Without this, comp discovery yields zero results.
RAPIDAPI_KEY=your_rapidapi_key_here


# --- Optional ---

# Comp data source. 'rapidapi' (default) uses live Zillow data; 'orpts' uses
# the NYS ORPTS RP-5217 sales file (license-clean, ~3-month lag, scaffold
# only as of 2026-05). Flip to 'orpts' when counsel rules on persistence.
# COMP_SOURCE=rapidapi

# Server signing key for the ToS-accepted cookie. If unset, a random per-
# process key is used (cookies invalidated on restart, which is acceptable
# for ToS gating). Set in prod for stable acceptance across deploys.
# GRIEVER_SESSION_SECRET=

# Sentry environment label (defaults to 'production').
# SENTRY_ENVIRONMENT=staging
# SENTRY_TRACES_SAMPLE_RATE=0.1


# Postgres connection string. When set, the app uses Postgres via psycopg2;
# when absent, it falls back to a local SQLite file (grievance_data.db).
# Format: postgresql://user:password@host:port/dbname
# Cloud SQL Unix socket form: postgresql://user:pass@/dbname?host=/cloudsql/PROJECT:REGION:INSTANCE
# DATABASE_URL=

# Sentry DSN for error tracking. Without this, Sentry init is a no-op and
# errors fall through to stdout logs.
# SENTRY_DSN=

# Redis URL for the RapidAPI response cache. Without this, every comp search
# hits the upstream API. Recommended for production to limit quota burn.
# REDIS_URL=redis://localhost:6379/0

# SMTP credentials for the legacy email-based error reporter in app.utils.
# Will be removed once Sentry replaces it; keep blank if SENTRY_DSN is set.
# SMTP_SERVER=
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
